var RF_SHEET_ID  = "1CNdpmmmxPuy77xxf8mM8MXBHB9JSvm_YzzrIbzYBqxA";
var RF_SHEET_TAB = "";   // kosong = sheet pertama. Isi nama tab bila perlu, mis. "Data".

function doPost(e) {
  try {
    var data = JSON.parse(e.postData.contents);   // objek flatRecord() dari survey
    var sh   = _rfSheet();

    var lastCol = sh.getLastColumn();
    var headers = lastCol > 0
      ? sh.getRange(1, 1, 1, lastCol).getValues()[0].map(function (h) { return String(h).trim(); })
      : [];

    // belum ada header sama sekali -> buat dari kunci data
    if (headers.length === 0 || headers.join("") === "") {
      headers = Object.keys(data);
      sh.getRange(1, 1, 1, headers.length).setValues([headers]);
    } else {
      // ada kunci baru yg belum ada di header -> tambahkan kolom (data lama tetap rapi)
      var added = false;
      Object.keys(data).forEach(function (k) {
        if (headers.indexOf(k) === -1) { headers.push(k); added = true; }
      });
      if (added) sh.getRange(1, 1, 1, headers.length).setValues([headers]);
    }

    // susun baris sesuai urutan header lalu append
    var row = headers.map(function (h) {
      var v = data[h];
      return (v === undefined || v === null) ? "" : v;
    });
    sh.appendRow(row);

    return _rfJson({ ok: true });
  } catch (err) {
    return _rfJson({ ok: false, error: String(err) });
  }
}

function _rfSheet() {
  var ss = SpreadsheetApp.openById(RF_SHEET_ID);
  var sh = RF_SHEET_TAB ? ss.getSheetByName(RF_SHEET_TAB) : ss.getSheets()[0];
  if (!sh && RF_SHEET_TAB) sh = ss.insertSheet(RF_SHEET_TAB);
  if (!sh) sh = ss.getSheets()[0];
  return sh;
}

function _rfJson(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}
